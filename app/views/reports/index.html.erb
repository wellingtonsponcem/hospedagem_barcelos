<% content_for :page_title, "Central de Relatórios" %>

<div class="max-w-7xl mx-auto w-full space-y-6">
  <!-- Page Header -->
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 bg-surface p-4 rounded-xl border border-outline-variant shadow-sm">
    <div>
      <h3 class="font-headline-sm text-headline-sm text-on-surface font-bold">Central de Relatórios</h3>
      <p class="text-xs text-on-surface-variant">Visão geral do desempenho operacional e financeiro da unidade Posto Barcelos.</p>
    </div>
    <div class="flex items-center gap-3">
      <div class="flex items-center bg-surface-container px-4 py-2 rounded-lg border border-outline-variant">
        <span class="material-symbols-outlined text-outline text-[18px] mr-2">calendar_today</span>
        <span class="text-xs font-label-bold text-on-surface-variant font-semibold"><%= l(Date.today.beginning_of_month, format: "%d/%m/%Y") %> — <%= l(Date.today.end_of_month, format: "%d/%m/%Y") %></span>
      </div>
      <button class="flex items-center gap-2 bg-primary text-on-primary px-4 py-2.5 rounded-lg font-label-bold text-xs hover:opacity-90 active:scale-[0.98] transition-all cursor-pointer border-none shadow-sm">
        <span class="material-symbols-outlined text-[16px]">file_download</span>
        Exportar PDF
      </button>
    </div>
  </div>

  <!-- Tab Navigation -->
  <div class="bg-white rounded-xl p-4 shadow-sm border border-outline-variant flex gap-2 overflow-x-auto whitespace-nowrap">
    <button class="flex items-center gap-2 px-4 py-2.5 rounded-lg text-on-primary-container bg-primary-container font-bold text-xs transition-all cursor-pointer border-none" id="tab-btn-indicadores" onclick="switchTab('indicadores')">
      <span class="material-symbols-outlined text-[18px]">analytics</span>
      Indicadores de Desempenho
    </button>
    <button class="flex items-center gap-2 px-4 py-2.5 rounded-lg text-on-surface-variant hover:bg-surface-container-high font-label-bold text-xs transition-all cursor-pointer bg-transparent border-none" id="tab-btn-financeiro" onclick="switchTab('financeiro')">
      <span class="material-symbols-outlined text-[18px]">account_balance_wallet</span>
      BI Financeiro e Rankings
    </button>
  </div>

  <!-- Content Areas -->
  <!-- Tab 1: Indicadores de Desempenho -->
  <div class="reports-section space-y-6" id="section-indicadores">
    <!-- Bento Grid Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="bg-white p-5 rounded-xl border border-outline-variant flex flex-col justify-between shadow-sm hover:border-primary/30 transition-colors h-[145px]">
        <div class="flex justify-between items-start">
          <div class="bg-primary/5 p-2.5 rounded-lg text-primary">
            <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 1;">layers</span>
          </div>
          <span class="flex items-center text-[10px] font-label-bold bg-green-50 text-green-700 px-2 py-0.5 rounded-full border border-green-200">
            <span class="material-symbols-outlined text-[12px] mr-0.5">trending_up</span> +5.2%
          </span>
        </div>
        <div>
          <p class="text-[10px] font-label-bold text-on-surface-variant uppercase tracking-wider mb-0.5">Taxa de Ocupação</p>
          <div class="flex items-baseline space-x-1">
            <span class="text-2xl font-bold text-on-surface"><%= @occupancy_rate %>%</span>
            <span class="text-outline text-[11px] font-semibold">/ 100%</span>
          </div>
        </div>
        <div class="h-1.5 w-full bg-surface-container-high rounded-full overflow-hidden">
          <div class="h-full bg-primary rounded-full transition-all" style="width: <%= @occupancy_rate %>%"></div>
        </div>
      </div>

      <div class="bg-white p-5 rounded-xl border border-outline-variant flex flex-col justify-between shadow-sm hover:border-primary/30 transition-colors h-[145px]">
        <div class="flex justify-between items-start">
          <div class="bg-secondary-container/20 p-2.5 rounded-lg text-secondary">
            <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 1;">account_balance_wallet</span>
          </div>
          <span class="text-[10px] font-label-bold bg-surface-container-high text-on-surface-variant px-2.5 py-0.5 rounded-full border border-outline-variant">Meta: R$ 15k</span>
        </div>
        <div>
          <p class="text-[10px] font-label-bold text-on-surface-variant uppercase tracking-wider mb-0.5">Faturamento Bruto</p>
          <div class="flex items-baseline">
            <span class="text-2xl font-bold text-on-surface"><%= number_to_currency(@month_total_revenue) %></span>
          </div>
        </div>
        <p class="text-[10px] font-body-md text-on-surface-variant flex items-center">
          <span class="material-symbols-outlined text-sm mr-1">info</span> 12% acima do período anterior
        </p>
      </div>

      <div class="bg-white p-5 rounded-xl border border-outline-variant flex flex-col justify-between shadow-sm hover:border-primary/30 transition-colors h-[145px]">
        <div class="flex justify-between items-start">
          <div class="bg-primary/5 p-2.5 rounded-lg text-primary">
            <span class="material-symbols-outlined text-[20px]">monitoring</span>
          </div>
        </div>
        <div>
          <p class="text-[10px] font-label-bold text-on-surface-variant uppercase tracking-wider mb-0.5">Diária Média (ADR)</p>
          <div class="flex items-baseline">
            <span class="text-2xl font-bold text-on-surface"><%= number_to_currency(@adr) %></span>
          </div>
        </div>
        <p class="text-[10px] text-on-surface-variant">Fórmula de rentabilidade operacional</p>
      </div>

      <div class="bg-white p-5 rounded-xl border border-outline-variant flex flex-col justify-between shadow-sm hover:border-primary/30 transition-colors h-[145px]">
        <div class="flex justify-between items-start">
          <div class="bg-tertiary/5 p-2.5 rounded-lg text-tertiary">
            <span class="material-symbols-outlined text-[20px]">finance_chip</span>
          </div>
        </div>
        <div>
          <p class="text-[10px] font-label-bold text-on-surface-variant uppercase tracking-wider mb-0.5">RevPAR</p>
          <div class="flex items-baseline">
            <span class="text-2xl font-bold text-on-surface"><%= number_to_currency(@revpar) %></span>
          </div>
        </div>
        <p class="text-[10px] text-on-surface-variant">Receita por quarto disponível</p>
      </div>
    </div>

    <!-- Charts Row -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
      <!-- Faturamento Mensal (Bar Chart) -->
      <div class="lg:col-span-8 bg-white p-6 rounded-xl border border-outline-variant shadow-sm flex flex-col justify-between h-[380px]">
        <div>
          <h4 class="text-base font-bold text-primary">Evolução do Faturamento Mensal</h4>
          <p class="text-[11px] text-on-surface-variant">Comparativo de receita bruta dos últimos 6 meses</p>
        </div>
        
        <!-- Render vertical bar graph -->
        <% max_value = @monthly_evolution.map { |x| x[:value] }.max.to_f %>
        <div class="flex-1 flex items-end justify-between px-6 pt-10 pb-2 relative h-[220px]">
          <!-- Grid lines -->
          <div class="absolute inset-x-0 bottom-8 h-px bg-surface-container-highest"></div>
          <div class="absolute inset-x-0 top-1/4 h-px border-t border-dashed border-outline-variant/30"></div>
          <div class="absolute inset-x-0 top-1/2 h-px border-t border-dashed border-outline-variant/30"></div>
          <div class="absolute inset-x-0 top-3/4 h-px border-t border-dashed border-outline-variant/30"></div>

          <% @monthly_evolution.each do |item| %>
            <% pct = max_value > 0 ? (item[:value] / max_value * 100).round : 0 %>
            <div class="flex flex-col items-center gap-2 w-[12%] group relative">
              <!-- Tooltip on hover -->
              <div class="absolute -top-8 bg-inverse-surface text-inverse-on-surface text-[10px] font-bold px-2 py-1 rounded shadow-md opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-10 whitespace-nowrap">
                <%= number_to_currency(item[:value]) %>
              </div>
              <div class="w-full bg-primary-container/20 rounded-t-lg h-[150px] flex items-end justify-center overflow-hidden">
                <div class="w-4 bg-primary rounded-t h-full transition-all duration-700 ease-out" style="height: <%= pct %>%"></div>
              </div>
              <span class="text-[10px] font-bold text-on-surface-variant uppercase"><%= item[:month] %></span>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Proporção de Hospedagens (Donut Chart) -->
      <div class="lg:col-span-4 bg-white p-6 rounded-xl border border-outline-variant shadow-sm flex flex-col justify-between h-[380px]">
        <div>
          <h4 class="text-base font-bold text-primary">Proporção de Hospedagens</h4>
          <p class="text-[11px] text-on-surface-variant">Classificação por modalidade de reserva</p>
        </div>
        
        <div class="flex-1 flex flex-col justify-center items-center py-2">
          <!-- SVG Donut Chart Mockup -->
          <div class="relative w-36 h-36">
            <svg class="w-full h-full transform -rotate-90" viewBox="0 0 160 160">
              <circle cx="80" cy="80" fill="transparent" r="65" stroke="#f1f4f6" stroke-width="15"></circle>
              <!-- Page slice (75%) -->
              <circle cx="80" cy="80" fill="transparent" r="65" stroke="#00347a" stroke-dasharray="408.4" stroke-dashoffset="102.1" stroke-width="15" stroke-linecap="round"></circle>
              <!-- Internal slice (15%) -->
              <circle cx="80" cy="80" fill="transparent" r="65" stroke="#fdd835" stroke-dasharray="408.4" stroke-dashoffset="347.1" stroke-width="15" stroke-linecap="round"></circle>
            </svg>
            <div class="absolute inset-0 flex items-center justify-center flex-col">
              <span class="text-xl font-headline-sm font-bold text-on-surface"><%= @month_reservations.count %></span>
              <span class="text-[9px] font-label-bold text-on-surface-variant uppercase tracking-wider">Reservas</span>
            </div>
          </div>
          
          <div class="mt-4 w-full space-y-1.5 text-xs">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <span class="w-2.5 h-2.5 rounded-full bg-primary inline-block"></span>
                <span>Pagas</span>
              </div>
              <span class="font-bold"><%= @res_type_percentages[:paga] %>%</span>
            </div>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <span class="w-2.5 h-2.5 rounded-full bg-secondary inline-block"></span>
                <span>Uso Interno</span>
              </div>
              <span class="font-bold"><%= @res_type_percentages[:interna] %>%</span>
            </div>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <span class="w-2.5 h-2.5 rounded-full bg-surface-variant inline-block"></span>
                <span>Cortesia</span>
              </div>
              <span class="font-bold"><%= @res_type_percentages[:cortesia] %>%</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Tab 2: BI Financeiro e Rankings -->
  <div class="reports-section space-y-6 hidden" id="section-financeiro">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Receita por Quarto -->
      <div class="bg-white rounded-xl border border-outline-variant overflow-hidden shadow-sm">
        <div class="p-5 border-b border-outline-variant bg-surface-container-low">
          <h4 class="text-sm font-bold text-primary">Receita Acumulada por Quarto</h4>
        </div>
        <div class="p-5 space-y-4">
          <% room_revenue = Reservation.group(:room_id).sum(:amount).sort_by { |_, v| -v }.first(5) %>
          <% if room_revenue.any? %>
            <% max_rev = room_revenue.map { |x| x[1] }.max.to_f %>
            <% room_revenue.each do |room_id, rev| %>
              <% room = Room.find_by(id: room_id) %>
              <% pct = max_rev > 0 ? (rev / max_rev * 100).round : 0 %>
              <div>
                <div class="flex justify-between text-xs font-semibold mb-1">
                  <span class="text-on-surface">Quarto <%= room&.number %> — <%= room&.room_type || "Padrão" %></span>
                  <span class="text-primary font-bold"><%= number_to_currency(rev) %></span>
                </div>
                <div class="w-full bg-surface-container rounded-full h-2">
                  <div class="bg-primary h-2 rounded-full transition-all" style="width: <%= pct %>%"></div>
                </div>
              </div>
            <% end %>
          <% else %>
            <p class="text-center text-xs text-on-surface-variant py-8">Sem movimentação financeira por quarto registrada.</p>
          <% end %>
        </div>
      </div>

      <!-- Média de Hóspedes & Ocupação -->
      <div class="bg-white rounded-xl border border-outline-variant overflow-hidden shadow-sm flex flex-col justify-between">
        <div class="p-5 border-b border-outline-variant bg-surface-container-low">
          <h4 class="text-sm font-bold text-primary">Métricas Operacionais</h4>
        </div>
        <div class="p-8 flex-1 flex flex-col justify-center items-center text-center">
          <span class="material-symbols-outlined text-primary text-4xl mb-2">groups</span>
          <p class="text-xs font-label-bold text-on-surface-variant uppercase tracking-wider">Média de Hóspedes/Dia</p>
          <h4 class="text-5xl font-bold text-on-surface leading-none mt-2"><%= @month_guest_avg > 0 ? @month_guest_avg : "—" %></h4>
          <p class="text-xs text-on-surface-variant mt-3">Média estimada com base nas estadias do mês.</p>
        </div>
      </div>
    </div>

    <!-- Ranking de Hóspedes (Fiéis) -->
    <div class="bg-white rounded-xl border border-outline-variant overflow-hidden shadow-sm">
      <div class="p-5 border-b border-outline-variant bg-surface-container-low">
        <h4 class="text-sm font-bold text-primary">Ranking de Hóspedes (Mais Frequentes)</h4>
      </div>
      <div class="divide-y divide-outline-variant">
        <% top_guests = Reservation.group(:guest_id).order("count_id DESC").count(:id).first(5) %>
        <% if top_guests.any? %>
          <% top_guests.each_with_index do |(guest_id, count), idx| %>
            <% guest = Guest.find_by(id: guest_id) %>
            <% 
              medal_class = case idx
                            when 0 then "text-yellow-500"
                            when 1 then "text-gray-400"
                            when 2 then "text-orange-500"
                            else "text-on-surface-variant opacity-60"
                            end
            %>
            <div class="p-4 flex items-center justify-between hover:bg-surface-container-low transition-colors">
              <div class="flex items-center gap-3">
                <span class="w-6 text-center font-bold text-sm <%= medal_class %>">#<%= idx + 1 %></span>
                <div class="w-8 h-8 rounded-full bg-primary-container text-on-primary-container flex items-center justify-center font-bold text-xs">
                  <%= guest&.initials || "H" %>
                </div>
                <div>
                  <p class="text-sm font-bold text-on-surface"><%= guest&.name %></p>
                  <p class="text-xs text-on-surface-variant"><%= guest&.phone %> · <%= guest&.city %></p>
                </div>
              </div>
              <span class="text-xs font-bold text-primary bg-primary-fixed px-3 py-1 rounded-full border border-primary/10">
                <%= count %> estadias
              </span>
            </div>
          <% end %>
        <% else %>
          <div class="p-8 text-center text-xs text-on-surface-variant">Sem dados de hospedagens registrados.</div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<script>
  function switchTab(tabName) {
    // Hide all sections
    const sections = document.querySelectorAll('.reports-section');
    sections.forEach(s => s.classList.add('hidden'));

    // Show selected section
    const currentSection = document.getElementById('section-' + tabName);
    if (currentSection) {
      currentSection.classList.remove('hidden');
    }

    // Update button styles
    const buttons = [
      { id: 'tab-btn-indicadores', name: 'indicadores' },
      { id: 'tab-btn-financeiro', name: 'financeiro' }
    ];

    buttons.forEach(btn => {
      const element = document.getElementById(btn.id);
      if (element) {
        if (btn.name === tabName) {
          element.classList.remove('text-on-surface-variant', 'hover:bg-surface-container-high', 'bg-transparent');
          element.classList.add('text-on-primary-container', 'bg-primary-container', 'font-bold');
        } else {
          element.classList.add('text-on-surface-variant', 'hover:bg-surface-container-high', 'bg-transparent');
          element.classList.remove('text-primary', 'bg-primary-container', 'font-bold');
        }
      }
    });

    // Update URL query parameter
    const url = new URL(window.location);
    url.searchParams.set('tab', tabName);
    window.history.replaceState({}, '', url);
  }

  // Set active tab based on query param on page load
  document.addEventListener('DOMContentLoaded', () => {
    const params = new URLSearchParams(window.location.search);
    const activeTab = params.get('tab') || 'indicadores';
    switchTab(activeTab);
  });
</script>
