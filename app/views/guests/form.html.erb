<% content_for :page_title, @guest.new_record? ? "Novo Hóspede" : "Editar Hóspede" %>

<div class="max-w-2xl mx-auto">
  <div class="bg-surface-container-lowest rounded-xl border border-outline-variant overflow-hidden shadow-sm">
    <!-- Header -->
    <div class="p-card-padding border-b border-outline-variant bg-surface-container-low">
      <div class="flex items-center gap-4">
        <div class="w-16 h-16 rounded-2xl bg-secondary-fixed text-on-secondary-fixed flex items-center justify-center font-bold text-2xl shadow-sm">
          <%= @guest.new_record? ? "N" : @guest.initials %>
        </div>
        <div>
          <h4 class="font-headline-sm text-on-surface"><%= @guest.new_record? ? "Novo Hóspede" : "Editar Hóspede" %></h4>
          <p class="text-on-surface-variant font-label-bold"><%= @guest.new_record? ? "Preencha os dados do hóspede" : "Altere as informações do hóspede" %></p>
        </div>
      </div>
    </div>

    <!-- Form -->
    <%= form_with model: @guest, local: true, class: "p-card-padding space-y-6" do |f| %>
      <% if @guest.errors.any? %>
        <div class="bg-error-container text-on-error-container p-4 rounded-lg">
          <p class="font-bold mb-2"><%= pluralize(@guest.errors.count, "erro") %>:</p>
          <ul class="list-disc pl-4 text-sm">
            <% @guest.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid grid-cols-2 gap-4">
        <div class="col-span-2">
          <%= f.label :name, "Nome Completo", class: "block text-label-bold text-on-surface-variant mb-1.5" %>
          <%= f.text_field :name, class: "w-full bg-background border border-outline-variant rounded-lg px-3 py-2 text-on-surface focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" %>
        </div>
        <div>
          <%= f.label :document, "Documento (CPF/RG)", class: "block text-label-bold text-on-surface-variant mb-1.5" %>
          <%= f.text_field :document, class: "w-full bg-background border border-outline-variant rounded-lg px-3 py-2 text-on-surface focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" %>
        </div>
        <div>
          <%= f.label :phone, "Telefone", class: "block text-label-bold text-on-surface-variant mb-1.5" %>
          <%= f.text_field :phone, class: "w-full bg-background border border-outline-variant rounded-lg px-3 py-2 text-on-surface focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" %>
        </div>
        <div>
          <%= f.label :plate, "Placa do Veículo", class: "block text-label-bold text-on-surface-variant mb-1.5" %>
          <%= f.text_field :plate, class: "w-full bg-background border border-outline-variant rounded-lg px-3 py-2 font-mono text-on-surface focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" %>
        </div>
        <div>
          <%= f.label :city, "Cidade/UF", class: "block text-label-bold text-on-surface-variant mb-1.5" %>
          <%= f.text_field :city, class: "w-full bg-background border border-outline-variant rounded-lg px-3 py-2 text-on-surface focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" %>
        </div>
        <div class="col-span-2">
          <%= f.label :company, "Empresa/Vínculo", class: "block text-label-bold text-on-surface-variant mb-1.5" %>
          <%= f.text_field :company, class: "w-full bg-background border border-outline-variant rounded-lg px-3 py-2 text-on-surface focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" %>
        </div>
        <div class="col-span-2">
          <%= f.label :notes, "Observações", class: "block text-label-bold text-on-surface-variant mb-1.5" %>
          <%= f.text_area :notes, class: "w-full bg-background border border-outline-variant rounded-lg px-3 py-2 text-on-surface focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all resize-none", placeholder: "Observações importantes sobre o hóspede...", rows: 3 %>
        </div>
      </div>

      <div class="flex gap-3 pt-4 border-t border-outline-variant">
        <%= link_to "Cancelar", guests_path, class: "flex-1 border border-outline text-on-surface font-label-bold py-2.5 rounded-lg hover:bg-surface-container-high transition-colors text-center" %>
        <%= f.submit (@guest.new_record? ? "Cadastrar Hóspede" : "Salvar Alterações"), class: "flex-1 bg-primary text-on-primary font-label-bold py-2.5 rounded-lg shadow-sm hover:opacity-90 active:scale-[0.98] transition-all cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
