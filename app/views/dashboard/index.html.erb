<% content_for :page_title, "Visão Geral" %>

<!-- KPI Cards -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
  <div class="bg-surface-container-lowest rounded-xl border border-outline-variant p-4 shadow-sm">
    <div class="flex items-center gap-2 mb-1">
      <span class="material-symbols-outlined text-primary">meeting_room</span>
      <span class="text-xs text-on-surface-variant">Quartos Ocupados</span>
    </div>
    <p class="text-3xl font-bold text-on-surface"><%= @occupied_rooms %></p>
    <p class="text-xs text-on-surface-variant">de <%= @total_rooms %> · <%= @available_rooms %> livres</p>
  </div>
  <div class="bg-surface-container-lowest rounded-xl border border-outline-variant p-4 shadow-sm">
    <div class="flex items-center gap-2 mb-1">
      <span class="material-symbols-outlined text-primary">today</span>
      <span class="text-xs text-on-surface-variant">Check-ins Hoje</span>
    </div>
    <p class="text-3xl font-bold text-on-surface"><%= @today_checkins %></p>
    <p class="text-xs text-on-surface-variant"><%= @today_checkouts %> check-outs previstos</p>
  </div>
  <div class="bg-surface-container-lowest rounded-xl border border-outline-variant p-4 shadow-sm">
    <div class="flex items-center gap-2 mb-1">
      <span class="material-symbols-outlined text-primary">shower</span>
      <span class="text-xs text-on-surface-variant">Banhos Ativos</span>
    </div>
    <p class="text-3xl font-bold text-on-surface"><%= @active_showers %></p>
    <p class="text-xs text-on-surface-variant">em andamento</p>
  </div>
  <div class="bg-surface-container-lowest rounded-xl border border-outline-variant p-4 shadow-sm">
    <div class="flex items-center gap-2 mb-1">
      <span class="material-symbols-outlined text-primary">payments</span>
      <span class="text-xs text-on-surface-variant">Receita Hoje</span>
    </div>
    <p class="text-3xl font-bold text-primary"><%= number_to_currency(@today_revenue) %></p>
    <p class="text-xs text-on-surface-variant">movimentação do dia</p>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <!-- Current Guests -->
  <div class="bg-surface-container-lowest rounded-xl border border-outline-variant overflow-hidden shadow-sm">
    <div class="p-4 border-b border-outline-variant bg-surface-container-low flex justify-between items-center">
      <h4 class="font-label-bold text-on-surface">Hóspedes no Hotel</h4>
      <%= link_to "Ver todos", reservations_path, class: "text-xs text-primary font-label-bold hover:underline" %>
    </div>
    <div class="divide-y divide-outline-variant">
      <% if @current_guests.any? %>
        <% @current_guests.each do |res| %>
          <div class="px-4 py-3 flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-primary-fixed text-on-primary-fixed flex items-center justify-center font-bold text-xs"><%= res.guest.initials %></div>
            <div class="flex-1">
              <p class="text-sm font-label-bold text-on-surface"><%= res.guest.name %></p>
              <p class="text-xs text-on-surface-variant">Quarto <%= res.room.number %> · Check-out: <%= res.check_out.strftime("%d/%m %H:%M") %></p>
            </div>
            <span class="text-xs px-2 py-1 rounded-full bg-primary-container text-on-primary-container font-label-bold"><%= res.status_text %></span>
          </div>
        <% end %>
      <% else %>
        <div class="p-6 text-center text-on-surface-variant">
          <span class="material-symbols-outlined text-3xl mb-2">meeting_room</span>
          <p>Nenhum hóspede no momento</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Quick Room Status -->
  <div class="bg-surface-container-lowest rounded-xl border border-outline-variant overflow-hidden shadow-sm">
    <div class="p-4 border-b border-outline-variant bg-surface-container-low flex justify-between items-center">
      <h4 class="font-label-bold text-on-surface">Status dos Quartos</h4>
      <%= link_to "Ver mapa", rooms_path, class: "text-xs text-primary font-label-bold hover:underline" %>
    </div>
    <div class="p-4">
      <div class="grid grid-cols-3 gap-3">
        <% Room.order(:number).each do |room| %>
          <div class="<%= room.status_color_class %> text-white rounded-lg p-3 text-center">
            <p class="font-bold text-sm"><%= room.number %></p>
            <p class="text-[10px] opacity-90"><%= room.status_text %></p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
