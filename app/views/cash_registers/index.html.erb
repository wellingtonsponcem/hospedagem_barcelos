<% content_for :page_title, "Financeiro" %>

<% if @current_cash_register %>
  <!-- Open Cash Register Dashboard -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
    <!-- Left: Overview -->
    <div class="lg:col-span-4 space-y-4">
      <div class="bg-surface-container-lowest rounded-xl border border-outline-variant overflow-hidden shadow-sm">
        <div class="p-4 border-b border-outline-variant bg-surface-container-low">
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-green-500"></span>
            <span class="font-label-bold text-on-surface">Caixa Aberto</span>
          </div>
        </div>
        <div class="p-4 space-y-3">
          <div class="flex justify-between text-sm">
            <span class="text-on-surface-variant">Abertura</span>
            <span class="font-label-bold"><%= @current_cash_register.opened_at.strftime("%d/%m %H:%M") %></span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-on-surface-variant">Saldo Inicial</span>
            <span class="font-label-bold"><%= number_to_currency(@current_cash_register.opening_balance) %></span>
          </div>
          <hr class="border-outline-variant">
          <div class="flex justify-between text-sm">
            <span class="text-on-surface-variant">Entradas</span>
            <span class="font-label-bold text-green-600">+ <%= number_to_currency(@total_in || 0) %></span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-on-surface-variant">Saídas</span>
            <span class="font-label-bold text-red-500">- <%= number_to_currency(@total_out || 0) %></span>
          </div>
          <hr class="border-outline-variant">
          <div class="flex justify-between">
            <span class="font-label-bold text-on-surface">Saldo Atual</span>
            <span class="font-label-bold text-xl text-primary"><%= number_to_currency(@balance || 0) %></span>
          </div>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="bg-surface-container-lowest rounded-xl border border-outline-variant overflow-hidden shadow-sm">
        <div class="p-4 border-b border-outline-variant bg-surface-container-low">
          <span class="font-label-bold text-on-surface">Ações Rápidas</span>
        </div>
        <div class="p-4 space-y-2">
          <button onclick="document.getElementById('pdv-modal').classList.remove('hidden')" class="w-full text-left bg-surface-container-high hover:bg-surface-container-lowest border border-outline-variant rounded-lg p-3 transition-all cursor-pointer flex items-center gap-3">
            <span class="material-symbols-outlined text-primary">point_of_sale</span>
            <div><p class="font-label-bold text-on-surface text-sm">Nova Entrada (PDV)</p><p class="text-xs text-on-surface-variant">Registrar pagamento</p></div>
          </button>
          <button onclick="document.getElementById('expense-modal').classList.remove('hidden')" class="w-full text-left bg-surface-container-high hover:bg-surface-container-lowest border border-outline-variant rounded-lg p-3 transition-all cursor-pointer flex items-center gap-3">
            <span class="material-symbols-outlined text-error">money_off</span>
            <div><p class="font-label-bold text-on-surface text-sm">Nova Saída</p><p class="text-xs text-on-surface-variant">Registrar despesa/retirada</p></div>
          </button>
          <button onclick="document.getElementById('close-cash-modal').classList.remove('hidden')" class="w-full text-left bg-error-container text-on-error-container hover:opacity-90 border border-error rounded-lg p-3 transition-all cursor-pointer flex items-center gap-3">
            <span class="material-symbols-outlined">lock</span>
            <div><p class="font-label-bold text-sm">Fechar Caixa</p><p class="text-xs opacity-80">Encerrar o movimento do dia</p></div>
          </button>
        </div>
      </div>
    </div>

    <!-- Right: Transactions -->
    <div class="lg:col-span-8">
      <div class="bg-white rounded-xl border border-outline-variant overflow-hidden shadow-sm">
        <div class="p-4 border-b border-outline-variant bg-surface-container-low flex items-center justify-between">
          <span class="font-label-bold text-on-surface">Movimentações de Hoje</span>
          <span class="text-xs text-on-surface-variant"><%= @today_transactions&.count || 0 %> registros</span>
        </div>
        <div class="divide-y divide-outline-variant max-h-[500px] overflow-y-auto">
          <% if @today_transactions&.any? %>
            <% @today_transactions.each do |t| %>
              <div class="px-4 py-3 flex items-center justify-between hover:bg-primary/5 transition-colors">
                <div class="flex items-center gap-3">
                  <span class="material-symbols-outlined <%= t.value > 0 ? 'text-green-600' : 'text-red-500' %>"><%= t.value > 0 ? 'arrow_circle_down' : 'arrow_circle_up' %></span>
                  <div>
                    <p class="text-sm font-label-bold text-on-surface"><%= t.description %></p>
                    <p class="text-xs text-on-surface-variant"><%= t.origin %> · <%= t.created_at.strftime("%H:%M") %><% if t.payment_method.present? %> · <%= t.payment_method %><% end %></p>
                  </div>
                </div>
                <span class="font-label-bold <%= t.value > 0 ? 'text-green-600' : 'text-red-500' %>">
                  <%= t.value > 0 ? "+" : "" %><%= number_to_currency(t.value) %>
                </span>
              </div>
            <% end %>
          <% else %>
            <div class="p-8 text-center text-on-surface-variant">
              <span class="material-symbols-outlined text-3xl mb-2">receipt_long</span>
              <p>Nenhuma movimentação hoje</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- PDV Modal -->
  <div id="pdv-modal" class="hidden fixed inset-0 z-50 bg-black/40 flex items-center justify-center p-4" onclick="if(event.target===this)this.classList.add('hidden')">
    <div class="bg-surface-container-lowest rounded-xl border border-outline-variant shadow-xl w-full max-w-md overflow-hidden" onclick="event.stopPropagation()">
      <div class="p-5 border-b border-outline-variant flex items-center justify-between">
        <h4 class="font-headline-sm text-on-surface flex items-center gap-2"><span class="material-symbols-outlined text-primary">point_of_sale</span> Nova Entrada (PDV)</h4>
        <button onclick="document.getElementById('pdv-modal').classList.add('hidden')" class="text-on-surface-variant hover:text-on-surface cursor-pointer"><span class="material-symbols-outlined">close</span></button>
      </div>
      <%= form_with model: Transaction.new, url: transactions_path, local: true, class: "p-5 space-y-4" do |f| %>
        <%= f.hidden_field :cash_register_id, value: @current_cash_register.id %>
        <%= f.hidden_field :transaction_type, value: "receita" %>
        <%= f.hidden_field :origin, value: "PDV" %>
        <div>
          <%= f.label :description, "Descrição", class: "block text-label-bold text-on-surface-variant mb-1.5" %>
          <%= f.text_field :description, class: "w-full bg-background border border-outline-variant rounded-lg px-3 py-2 focus:ring-2 focus:ring-primary outline-none transition-all", placeholder: "Ex: Diária 203" %>
        </div>
        <div>
          <%= f.label :value, "Valor (R$)", class: "block text-label-bold text-on-surface-variant mb-1.5" %>
          <%= f.number_field :value, step: "0.01", class: "w-full bg-background border border-outline-variant rounded-lg px-3 py-2 focus:ring-2 focus:ring-primary outline-none transition-all" %>
        </div>
        <div>
          <%= f.label :payment_method, "Forma de Pagamento", class: "block text-label-bold text-on-surface-variant mb-1.5" %>
          <%= f.select :payment_method, [ "Dinheiro", "Cartão Débito", "Cartão Crédito", "PIX", "Fiado", "Empresa / NF" ], { prompt: "Selecione..." }, class: "w-full bg-background border border-outline-variant rounded-lg px-3 py-2 focus:ring-2 focus:ring-primary outline-none transition-all" %>
        </div>
        <div>
          <%= f.label :responsible, "Responsável", class: "block text-label-bold text-on-surface-variant mb-1.5" %>
          <%= f.text_field :responsible, class: "w-full bg-background border border-outline-variant rounded-lg px-3 py-2 focus:ring-2 focus:ring-primary outline-none transition-all" %>
        </div>
        <div class="flex gap-3 pt-2">
          <button type="button" onclick="document.getElementById('pdv-modal').classList.add('hidden')" class="flex-1 border border-outline text-on-surface font-label-bold py-2.5 rounded-lg hover:bg-surface-container-high transition-colors cursor-pointer">Cancelar</button>
          <%= f.submit "Registrar Entrada", class: "flex-1 bg-primary text-on-primary font-label-bold py-2.5 rounded-lg shadow-sm hover:opacity-90 active:scale-[0.98] transition-all cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Expense Modal -->
  <div id="expense-modal" class="hidden fixed inset-0 z-50 bg-black/40 flex items-center justify-center p-4" onclick="if(event.target===this)this.classList.add('hidden')">
    <div class="bg-surface-container-lowest rounded-xl border border-outline-variant shadow-xl w-full max-w-md overflow-hidden" onclick="event.stopPropagation()">
      <div class="p-5 border-b border-outline-variant flex items-center justify-between">
        <h4 class="font-headline-sm text-on-surface flex items-center gap-2"><span class="material-symbols-outlined text-error">money_off</span> Nova Saída</h4>
        <button onclick="document.getElementById('expense-modal').classList.add('hidden')" class="text-on-surface-variant hover:text-on-surface cursor-pointer"><span class="material-symbols-outlined">close</span></button>
      </div>
      <%= form_with model: Transaction.new, url: transactions_path, local: true, class: "p-5 space-y-4" do |f| %>
        <%= f.hidden_field :cash_register_id, value: @current_cash_register.id %>
        <%= f.hidden_field :transaction_type, value: "despesa" %>
        <%= f.hidden_field :origin, value: "PDV" %>
        <div>
          <%= f.label :description, "Descrição", class: "block text-label-bold text-on-surface-variant mb-1.5" %>
          <%= f.text_field :description, class: "w-full bg-background border border-outline-variant rounded-lg px-3 py-2 focus:ring-2 focus:ring-primary outline-none transition-all", placeholder: "Ex: Água, luz, material..." %>
        </div>
        <div>
          <%= f.label :value, "Valor (R$)", class: "block text-label-bold text-on-surface-variant mb-1.5" %>
          <%= f.number_field :value, step: "0.01", class: "w-full bg-background border border-outline-variant rounded-lg px-3 py-2 focus:ring-2 focus:ring-primary outline-none transition-all" %>
        </div>
        <div>
          <%= f.label :responsible, "Responsável", class: "block text-label-bold text-on-surface-variant mb-1.5" %>
          <%= f.text_field :responsible, class: "w-full bg-background border border-outline-variant rounded-lg px-3 py-2 focus:ring-2 focus:ring-primary outline-none transition-all" %>
        </div>
        <div class="flex gap-3 pt-2">
          <button type="button" onclick="document.getElementById('expense-modal').classList.add('hidden')" class="flex-1 border border-outline text-on-surface font-label-bold py-2.5 rounded-lg hover:bg-surface-container-high transition-colors cursor-pointer">Cancelar</button>
          <%= f.submit "Registrar Saída", class: "flex-1 bg-error text-white font-label-bold py-2.5 rounded-lg shadow-sm hover:opacity-90 active:scale-[0.98] transition-all cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Close Cash Modal -->
  <div id="close-cash-modal" class="hidden fixed inset-0 z-50 bg-black/40 flex items-center justify-center p-4" onclick="if(event.target===this)this.classList.add('hidden')">
    <div class="bg-surface-container-lowest rounded-xl border border-outline-variant shadow-xl w-full max-w-md overflow-hidden" onclick="event.stopPropagation()">
      <div class="p-5 border-b border-outline-variant">
        <h4 class="font-headline-sm text-on-surface flex items-center gap-2"><span class="material-symbols-outlined">lock</span> Fechar Caixa</h4>
      </div>
      <%= form_with url: close_cash_registers_path, local: true, method: :post, class: "p-5 space-y-4" do |f| %>
        <%= hidden_field_tag :id, @current_cash_register.id %>
        <div class="bg-surface-container-high rounded-lg p-4 space-y-2">
          <div class="flex justify-between text-sm"><span class="text-on-surface-variant">Saldo Inicial</span><span class="font-label-bold"><%= number_to_currency(@current_cash_register.opening_balance) %></span></div>
          <div class="flex justify-between text-sm"><span class="text-on-surface-variant">Entradas</span><span class="font-label-bold text-green-600">+ <%= number_to_currency(@total_in || 0) %></span></div>
          <div class="flex justify-between text-sm"><span class="text-on-surface-variant">Saídas</span><span class="font-label-bold text-red-500">- <%= number_to_currency(@total_out || 0) %></span></div>
          <hr class="border-outline-variant">
          <div class="flex justify-between"><span class="font-label-bold text-on-surface">Saldo Esperado</span><span class="font-label-bold text-lg text-primary"><%= number_to_currency(@balance || 0) %></span></div>
        </div>
        <div>
          <%= f.label :closing_balance, "Saldo Informado (R$)", class: "block text-label-bold text-on-surface-variant mb-1.5" %>
          <%= f.number_field :closing_balance, step: "0.01", class: "w-full bg-background border border-outline-variant rounded-lg px-3 py-2 focus:ring-2 focus:ring-primary outline-none transition-all" %>
        </div>
        <div class="flex gap-3 pt-2">
          <button type="button" onclick="document.getElementById('close-cash-modal').classList.add('hidden')" class="flex-1 border border-outline text-on-surface font-label-bold py-2.5 rounded-lg hover:bg-surface-container-high transition-colors cursor-pointer">Cancelar</button>
          <%= f.submit "Fechar Caixa", class: "flex-1 bg-error text-white font-label-bold py-2.5 rounded-lg shadow-sm hover:opacity-90 active:scale-[0.98] transition-all cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </div>
<% else %>
  <!-- No Open Cash Register -->
  <div class="max-w-md mx-auto mt-12 text-center bg-surface-container-lowest rounded-xl border border-outline-variant p-8 shadow-sm">
    <span class="material-symbols-outlined text-5xl text-primary mb-4">point_of_sale</span>
    <h3 class="font-headline-sm text-on-surface mb-2">Abrir Caixa</h3>
    <p class="text-on-surface-variant font-body-md mb-6">Informe o saldo inicial para começar o movimento do dia.</p>
    <%= form_with model: @cash_register, local: true, class: "space-y-4" do |f| %>
      <% if @cash_register.errors.any? %>
        <div class="bg-error-container text-on-error-container p-3 rounded-lg text-sm">
          <% @cash_register.errors.full_messages.each do |msg| %>
            <p><%= msg %></p>
          <% end %>
        </div>
      <% end %>
      <div>
        <%= f.label :opening_balance, "Saldo Inicial (R$)", class: "block text-label-bold text-on-surface-variant mb-1.5 text-left" %>
        <%= f.number_field :opening_balance, step: "0.01", value: 200.00, class: "w-full bg-background border border-outline-variant rounded-lg px-4 py-3 text-lg focus:ring-2 focus:ring-primary outline-none transition-all" %>
      </div>
      <%= f.submit "Abrir Caixa", class: "w-full bg-primary text-on-primary font-label-bold py-3 rounded-lg shadow-sm hover:opacity-90 active:scale-[0.98] transition-all cursor-pointer text-lg" %>
    <% end %>
  </div>
<% end %>
