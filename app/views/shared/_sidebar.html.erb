<aside class="h-screen w-64 fixed left-0 top-0 bg-surface-container-low border-r border-outline-variant flex flex-col p-4 gap-2 hidden md:flex z-40">
  <div class="flex flex-col gap-1 mb-6 px-2">
    <h1 class="font-headline-md text-headline-md text-primary">Posto Barcelos</h1>
    <p class="text-on-surface-variant font-label-bold text-[10px] uppercase tracking-wider">Gestão de Hospedagem</p>
  </div>
  <nav class="flex-1 flex flex-col gap-1">
    <a class="flex items-center gap-3 px-4 py-3 rounded-lg transition-all scale-95 active:scale-90 font-label-bold text-label-bold <%= current_page?(dashboard_path) ? 'bg-primary-container text-on-primary-container font-bold' : 'text-on-surface-variant hover:bg-surface-container-high' %>" href="<%= dashboard_path %>">
      <span class="material-symbols-outlined">dashboard</span>
      Dashboard
    </a>
    <a class="flex items-center gap-3 px-4 py-3 rounded-lg transition-all scale-95 active:scale-90 font-label-bold text-label-bold <%= current_page?(rooms_path) ? 'bg-primary-container text-on-primary-container font-bold' : 'text-on-surface-variant hover:bg-surface-container-high' %>" href="<%= rooms_path %>">
      <span class="material-symbols-outlined">grid_view</span>
      Mapa de Quartos
    </a>
    <a class="flex items-center gap-3 px-4 py-3 rounded-lg transition-all scale-95 active:scale-90 font-label-bold text-label-bold <%= controller_name == 'guests' ? 'bg-primary-container text-on-primary-container font-bold' : 'text-on-surface-variant hover:bg-surface-container-high' %>" href="<%= guests_path %>">
      <span class="material-symbols-outlined">group</span>
      Hóspedes
    </a>
    <a class="flex items-center gap-3 px-4 py-3 rounded-lg transition-all scale-95 active:scale-90 font-label-bold text-label-bold <%= controller_name == 'reservations' ? 'bg-primary-container text-on-primary-container font-bold' : 'text-on-surface-variant hover:bg-surface-container-high' %>" href="<%= reservations_path %>">
      <span class="material-symbols-outlined">event_available</span>
      Reservas
    </a>
    <a class="flex items-center gap-3 px-4 py-3 rounded-lg transition-all scale-95 active:scale-90 font-label-bold text-label-bold <%= controller_name == 'showers' ? 'bg-primary-container text-on-primary-container font-bold' : 'text-on-surface-variant hover:bg-surface-container-high' %>" href="<%= showers_path %>">
      <span class="material-symbols-outlined">bathtub</span>
      Banho Avulso
    </a>
    <a class="flex items-center gap-3 px-4 py-3 rounded-lg transition-all scale-95 active:scale-90 font-label-bold text-label-bold <%= controller_name == 'cash_registers' ? 'bg-primary-container text-on-primary-container font-bold' : 'text-on-surface-variant hover:bg-surface-container-high' %>" href="<%= cash_registers_path %>">
      <span class="material-symbols-outlined">payments</span>
      Caixa
    </a>
    <a class="flex items-center gap-3 px-4 py-3 rounded-lg transition-all scale-95 active:scale-90 font-label-bold text-label-bold <%= controller_name == 'reports' ? 'bg-primary-container text-on-primary-container font-bold' : 'text-on-surface-variant hover:bg-surface-container-high' %>" href="<%= reports_path %>">
      <span class="material-symbols-outlined">assessment</span>
      Relatórios
    </a>
    <a class="flex items-center gap-3 px-4 py-3 rounded-lg transition-all scale-95 active:scale-90 font-label-bold text-label-bold <%= controller_name == 'settings' ? 'bg-primary-container text-on-primary-container font-bold' : 'text-on-surface-variant hover:bg-surface-container-high' %>" href="<%= settings_path %>">
      <span class="material-symbols-outlined">settings</span>
      Configurações
    </a>
  </nav>

  <div class="mt-auto p-4 bg-surface-container rounded-xl flex items-center gap-3">
    <div class="w-10 h-10 rounded-full overflow-hidden bg-primary-container flex items-center justify-center text-on-primary-container font-bold">
      <%= current_user&.name&.split&.map(&:first)&.join&.upcase || "AD" %>
    </div>
    <div class="min-w-0 flex-1">
      <p class="font-label-bold text-label-bold text-on-surface truncate"><%= current_user&.name || "Administrador" %></p>
      <p class="text-[10px] text-on-surface-variant truncate">Gerente de Turno</p>
    </div>
    <%= link_to logout_path, class: "text-on-surface-variant hover:text-error transition-colors p-1.5 hover:bg-surface-container-high rounded-full flex items-center justify-center", title: "Sair" do %>
      <span class="material-symbols-outlined text-lg">logout</span>
    <% end %>
  </div>
</aside>
