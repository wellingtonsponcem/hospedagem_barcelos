<% content_for :page_title, @reservation.new_record? ? "Nova Reserva" : "Editar Reserva" %>

<div class="max-w-3xl mx-auto">
  <div class="bg-surface-container-lowest rounded-xl border border-outline-variant overflow-hidden shadow-sm">
    <div class="p-card-padding border-b border-outline-variant bg-surface-container-low">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-xl bg-primary-fixed text-on-primary-fixed flex items-center justify-center">
          <span class="material-symbols-outlined">calendar_add_on</span>
        </div>
        <div>
          <h4 class="font-headline-sm text-on-surface"><%= @reservation.new_record? ? "Nova Reserva" : "Editar Reserva" %></h4>
          <p class="text-on-surface-variant font-label-bold">Preencha os dados da hospedagem</p>
        </div>
      </div>
    </div>

    <%= form_with model: @reservation, local: true, class: "p-card-padding space-y-6" do |f| %>
      <% if @reservation.errors.any? %>
        <div class="bg-error-container text-on-error-container p-4 rounded-lg">
          <p class="font-bold mb-2"><%= pluralize(@reservation.errors.count, "erro") %>:</p>
          <ul class="list-disc pl-4 text-sm">
            <% @reservation.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :guest_id, "Hóspede", class: "block text-label-bold text-on-surface-variant mb-1.5" %>
          <%= f.collection_select :guest_id, @guests, :id, :name, { prompt: "Selecione..." }, class: "w-full bg-background border border-outline-variant rounded-lg px-3 py-2 text-on-surface focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" %>
          <p class="text-xs text-on-surface-variant mt-1"><%= link_to "+ Novo hóspede", new_guest_path, class: "text-primary hover:underline" %></p>
        </div>
        <div>
          <%= f.label :room_id, "Quarto", class: "block text-label-bold text-on-surface-variant mb-1.5" %>
          <%= f.collection_select :room_id, @rooms, :id, ->(r) { "#{r.number} — #{r.name} (#{r.status_text})" }, { prompt: "Selecione..." }, class: "w-full bg-background border border-outline-variant rounded-lg px-3 py-2 text-on-surface focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" %>
        </div>
        <div>
          <%= f.label :check_in, "Check-in", class: "block text-label-bold text-on-surface-variant mb-1.5" %>
          <%= f.datetime_local_field :check_in, class: "w-full bg-background border border-outline-variant rounded-lg px-3 py-2 text-on-surface focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" %>
        </div>
        <div>
          <%= f.label :check_out, "Check-out", class: "block text-label-bold text-on-surface-variant mb-1.5" %>
          <%= f.datetime_local_field :check_out, class: "w-full bg-background border border-outline-variant rounded-lg px-3 py-2 text-on-surface focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" %>
        </div>
        <div>
          <%= f.label :reservation_type, "Tipo", class: "block text-label-bold text-on-surface-variant mb-1.5" %>
          <%= f.select :reservation_type, [ [ "Paga", "paga" ], [ "Cortesia", "cortesia" ], [ "Empresa", "empresa" ] ], {}, class: "w-full bg-background border border-outline-variant rounded-lg px-3 py-2 text-on-surface focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" %>
        </div>
        <div>
          <%= f.label :amount, "Valor (R$)", class: "block text-label-bold text-on-surface-variant mb-1.5" %>
          <%= f.number_field :amount, step: "0.01", class: "w-full bg-background border border-outline-variant rounded-lg px-3 py-2 text-on-surface focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" %>
          <p class="text-xs text-on-surface-variant mt-1">Deixe em branco para calcular automaticamente</p>
        </div>
        <div class="col-span-2">
          <%= f.label :notes, "Observações", class: "block text-label-bold text-on-surface-variant mb-1.5" %>
          <%= f.text_area :notes, class: "w-full bg-background border border-outline-variant rounded-lg px-3 py-2 text-on-surface focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all resize-none", rows: 2 %>
        </div>
      </div>

      <div class="flex gap-3 pt-4 border-t border-outline-variant">
        <%= link_to "Cancelar", reservations_path, class: "flex-1 border border-outline text-on-surface font-label-bold py-2.5 rounded-lg hover:bg-surface-container-high transition-colors text-center" %>
        <%= f.submit (@reservation.new_record? ? "Criar Reserva" : "Salvar"), class: "flex-1 bg-primary text-on-primary font-label-bold py-2.5 rounded-lg shadow-sm hover:opacity-90 active:scale-[0.98] transition-all cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
