<% content_for :page_title, "Check-out" %>

<div class="max-w-4xl mx-auto">
  <!-- Guest & Room Info -->
  <div class="bg-surface-container-lowest rounded-xl border border-outline-variant overflow-hidden shadow-sm mb-6">
    <div class="p-card-padding border-b border-outline-variant bg-surface-container-low">
      <div class="flex items-center gap-4">
        <div class="w-14 h-14 rounded-full bg-secondary-fixed text-on-secondary-fixed flex items-center justify-center font-bold text-xl">
          <%= @reservation.guest.initials %>
        </div>
        <div class="flex-1">
          <h4 class="font-headline-sm text-on-surface"><%= @reservation.guest.name %></h4>
          <p class="text-on-surface-variant">Quarto <%= @reservation.room.number %> — <%= @reservation.check_in.strftime("%d/%m/%Y") %> a <%= @reservation.check_out.strftime("%d/%m/%Y") %></p>
        </div>
        <div class="text-right">
          <p class="text-2xl font-bold text-primary"><%= number_to_currency(@total) %></p>
          <p class="text-xs text-on-surface-variant">Valor total</p>
        </div>
      </div>
    </div>

    <!-- Inspection Checklist -->
    <div class="p-card-padding border-b border-outline-variant">
      <h5 class="font-label-bold text-on-surface mb-4 flex items-center gap-2">
        <span class="material-symbols-outlined text-primary">inventory_2</span>
        Vistoria do Quarto
      </h5>
      <%= form_with url: "#", local: true, id: "inspection-form" do %>
        <% items = [ "Toalhas (quantidade)", "Lençóis", "Travesseiros", "Controle TV", "Chave / Cartão", "Minibar", "Secador", "Cabides" ] %>
        <div class="overflow-x-auto">
          <table class="w-full text-left text-sm">
            <thead>
              <tr class="border-b border-outline-variant">
                <th class="py-2 pr-4 font-label-bold text-on-surface-variant">Item</th>
                <th class="py-2 px-3 font-label-bold text-on-surface-variant text-center">OK</th>
                <th class="py-2 px-3 font-label-bold text-on-surface-variant text-center">Faltando</th>
                <th class="py-2 px-3 font-label-bold text-on-surface-variant text-center">Danificado</th>
              </tr>
            </thead>
            <tbody>
              <% items.each do |item| %>
                <tr class="border-b border-outline-variant/50">
                  <td class="py-2.5 pr-4 text-on-surface"><%= item %></td>
                  <td class="py-2.5 px-3 text-center"><input type="radio" name="inspection[<%= item.parameterize %>]" value="ok" checked class="accent-primary"></td>
                  <td class="py-2.5 px-3 text-center"><input type="radio" name="inspection[<%= item.parameterize %>]" value="missing" class="accent-error"></td>
                  <td class="py-2.5 px-3 text-center"><input type="radio" name="inspection[<%= item.parameterize %>]" value="damaged" class="accent-warning"></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    </div>

    <!-- Charges / Transactions -->
    <div class="p-card-padding border-b border-outline-variant">
      <h5 class="font-label-bold text-on-surface mb-4 flex items-center gap-2">
        <span class="material-symbols-outlined text-primary">receipt</span>
        Extrato de Consumo
      </h5>
      <% if @transactions.any? %>
        <div class="space-y-2">
          <% @transactions.each do |t| %>
            <div class="flex justify-between items-center py-2 border-b border-outline-variant/50 text-sm">
              <div>
                <p class="text-on-surface"><%= t.description %></p>
                <p class="text-xs text-on-surface-variant"><%= t.transaction_type %> · <%= t.created_at.strftime("%d/%m %H:%M") %></p>
              </div>
              <span class="font-label-bold text-on-surface">+ <%= number_to_currency(t.value) %></span>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-on-surface-variant text-sm">Nenhum consumo extra registrado.</p>
      <% end %>
    </div>

    <!-- Total & Payment -->
    <div class="p-card-padding">
      <div class="flex justify-between items-center mb-4">
        <h5 class="font-label-bold text-on-surface">Total a Pagar</h5>
        <span class="text-3xl font-bold text-primary"><%= number_to_currency(@total) %></span>
      </div>

      <div class="grid grid-cols-3 gap-3 mb-6">
        <button class="bg-surface-container-high border border-outline-variant rounded-lg p-3 text-center hover:bg-surface-container-lowest transition-all cursor-pointer active:scale-[0.98]" onclick="selectPayment(this, 'Dinheiro')">
          <span class="material-symbols-outlined text-primary">payments</span>
          <p class="text-xs font-label-bold text-on-surface mt-1">Dinheiro</p>
        </button>
        <button class="bg-surface-container-high border border-outline-variant rounded-lg p-3 text-center hover:bg-surface-container-lowest transition-all cursor-pointer active:scale-[0.98]" onclick="selectPayment(this, 'Cartão Débito')">
          <span class="material-symbols-outlined text-primary">credit_card</span>
          <p class="text-xs font-label-bold text-on-surface mt-1">Débito</p>
        </button>
        <button class="bg-surface-container-high border border-outline-variant rounded-lg p-3 text-center hover:bg-surface-container-lowest transition-all cursor-pointer active:scale-[0.98]" onclick="selectPayment(this, 'Cartão Crédito')">
          <span class="material-symbols-outlined text-primary">credit_score</span>
          <p class="text-xs font-label-bold text-on-surface mt-1">Crédito</p>
        </button>
        <button class="bg-surface-container-high border border-outline-variant rounded-lg p-3 text-center hover:bg-surface-container-lowest transition-all cursor-pointer active:scale-[0.98]" onclick="selectPayment(this, 'PIX')">
          <span class="material-symbols-outlined text-primary">qr_code</span>
          <p class="text-xs font-label-bold text-on-surface mt-1">PIX</p>
        </button>
        <button class="bg-surface-container-high border border-outline-variant rounded-lg p-3 text-center hover:bg-surface-container-lowest transition-all cursor-pointer active:scale-[0.98]" onclick="selectPayment(this, 'Empresa / NF')">
          <span class="material-symbols-outlined text-primary">receipt_long</span>
          <p class="text-xs font-label-bold text-on-surface mt-1">NF</p>
        </button>
        <button class="bg-surface-container-high border border-outline-variant rounded-lg p-3 text-center hover:bg-surface-container-lowest transition-all cursor-pointer" onclick="selectPayment(this, 'Fiado')">
          <span class="material-symbols-outlined text-primary">book</span>
          <p class="text-xs font-label-bold text-on-surface mt-1">Fiado</p>
        </button>
      </div>

      <div class="flex gap-3">
        <%= link_to "Voltar", reservations_path, class: "flex-1 border border-outline text-on-surface font-label-bold py-2.5 rounded-lg hover:bg-surface-container-high transition-colors text-center" %>
        <%= form_with url: "#", local: true, class: "flex-1" do %>
          <%= hidden_field_tag :payment_method, "", id: "payment-method-input" %>
          <button type="submit" class="w-full bg-primary text-on-primary font-label-bold py-2.5 rounded-lg shadow-sm hover:opacity-90 active:scale-[0.98] transition-all cursor-pointer" onclick="return confirmPayment()">
            Finalizar Check-out
          </button>
        <% end %>
      </div>
    </div>
  </div>
</div>

<script>
  let selectedPayment = null;
  function selectPayment(el, method) {
    document.querySelectorAll('#inspection-form .grid button, [onclick*="selectPayment"]').forEach(b => b.classList.remove('ring-2', 'ring-primary'));
    el.classList.add('ring-2', 'ring-primary');
    selectedPayment = method;
    document.getElementById('payment-method-input').value = method;
  }
  function confirmPayment() {
    if (!selectedPayment) { alert('Selecione uma forma de pagamento.'); return false; }
    return confirm(`Confirmar check-out com pagamento em ${selectedPayment}?`);
  }
</script>
