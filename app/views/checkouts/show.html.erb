<% content_for :page_title, "Check-out e Vistoria" %>

<div class="max-w-5xl mx-auto w-full space-y-6">
  <!-- Summary Header (Resumo da Hospedagem) -->
  <div class="bg-surface-container-lowest border border-outline-variant rounded-xl shadow-sm overflow-hidden">
    <div class="bg-primary px-card-padding py-4">
      <h2 class="text-on-primary font-headline-sm text-headline-sm flex items-center gap-2">
        <span class="material-symbols-outlined">fact_check</span>
        Finalização de Estadia
      </h2>
    </div>
    <div class="p-card-padding grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="flex flex-col">
        <span class="text-label-bold font-label-bold text-outline uppercase tracking-wider mb-1">Hóspede</span>
        <span class="text-body-lg font-bold text-on-surface"><%= @reservation.guest.name %></span>
        <span class="text-body-md text-on-surface-variant">Documento: <%= @reservation.guest.document.presence || "Não cadastrado" %></span>
      </div>
      <div class="flex flex-col">
        <span class="text-label-bold font-label-bold text-outline uppercase tracking-wider mb-1">Acomodação</span>
        <span class="text-body-lg font-bold text-on-surface">Quarto <%= @reservation.room.number %> - <%= @reservation.room.name %></span>
        <span class="text-body-md text-on-surface-variant"><%= @reservation.room.room_type %></span>
      </div>
      <div class="flex flex-col">
        <span class="text-label-bold font-label-bold text-outline uppercase tracking-wider mb-1">Período</span>
        <span class="text-body-lg font-bold text-on-surface"><%= @reservation.check_in.strftime("%d/%m") %> - <%= @reservation.check_out.strftime("%d/%m") %> (<%= @reservation.duration_days %> Diárias)</span>
        <span class="text-body-md text-on-surface-variant">Check-out previsto: <%= @reservation.check_out.strftime("%H:%M") %></span>
      </div>
    </div>
  </div>

  <!-- Mandatory Inspection Checklist -->
  <%= form_with url: checkout_path(@reservation), method: :patch, local: true, class: "space-y-6" do |f| %>
    <div class="bg-surface-container-lowest border border-outline-variant rounded-xl shadow-sm overflow-hidden">
      <div class="px-card-padding py-4 border-b border-outline-variant flex justify-between items-center bg-surface-container-low">
        <h3 class="text-on-surface font-headline-sm text-headline-sm flex items-center gap-2">
          <span class="material-symbols-outlined text-primary">inventory</span>
          Checklist de Vistoria Obrigatória
        </h3>
        <span class="bg-error-container text-on-error-container text-label-bold font-label-bold px-3 py-1 rounded-full flex items-center gap-1 animate-pulse">
          <span class="material-symbols-outlined text-sm">warning</span>
          Preenchimento Obrigatório
        </span>
      </div>
      
      <div class="p-card-padding space-y-4">
        <p class="text-on-surface-variant text-body-md italic mb-4">Verifique cuidadosamente o enxoval e itens do quarto para evitar prejuízos operacionais.</p>
        
        <!-- Checklist Grid -->
        <div class="grid grid-cols-1 gap-4">
          <% items = [
            { id: "lencol", label: "Lençol", icon: "bed" },
            { id: "fronha", label: "Fronha", icon: "pill" },
            { id: "cobertor", label: "Cobertor", icon: "blanket" },
            { id: "toalha", label: "Toalha de Banho", icon: "dry_cleaning" },
            { id: "chave", label: "Chave / Controle", icon: "vpn_key" }
          ] %>

          <% items.each do |item| %>
            <div class="flex flex-col sm:flex-row sm:items-center justify-between p-4 bg-surface rounded-lg border border-outline-variant group hover:border-primary transition-colors">
              <div class="flex items-center gap-4 mb-4 sm:mb-0">
                <div class="w-10 h-10 rounded-full bg-primary-fixed flex items-center justify-center text-primary">
                  <span class="material-symbols-outlined"><%= item[:icon] %></span>
                </div>
                <span class="font-bold text-body-lg"><%= item[:label] %></span>
              </div>
              
              <div class="flex gap-2">
                <label class="flex-1 sm:flex-none">
                  <input type="radio" name="inspection[<%= item[:id] %>]" value="ok" checked class="hidden peer">
                  <div class="flex items-center justify-center gap-2 px-4 py-2 rounded-lg border border-outline-variant bg-surface cursor-pointer peer-checked:bg-primary peer-checked:text-white peer-checked:border-primary transition-all font-label-bold text-label-bold">
                    <span class="material-symbols-outlined text-sm">check_circle</span> OK
                  </div>
                </label>
                
                <label class="flex-1 sm:flex-none">
                  <input type="radio" name="inspection[<%= item[:id] %>]" value="faltando" class="hidden peer">
                  <div class="flex items-center justify-center gap-2 px-4 py-2 rounded-lg border border-outline-variant bg-surface cursor-pointer peer-checked:bg-error peer-checked:text-white peer-checked:border-error transition-all font-label-bold text-label-bold">
                    <span class="material-symbols-outlined text-sm">cancel</span> Faltando
                  </div>
                </label>
                
                <label class="flex-1 sm:flex-none">
                  <input type="radio" name="inspection[<%= item[:id] %>]" value="danificado" class="hidden peer">
                  <div class="flex items-center justify-center gap-2 px-4 py-2 rounded-lg border border-outline-variant bg-surface cursor-pointer peer-checked:bg-secondary-container peer-checked:text-on-secondary-container peer-checked:border-secondary-container transition-all font-label-bold text-label-bold">
                    <span class="material-symbols-outlined text-sm">error</span> Danificado
                  </div>
                </label>
              </div>
            </div>
          <% end %>
        </div>

        <!-- Observation & Photo Attachment -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-gutter mt-8">
          <div class="flex flex-col gap-2">
            <label class="text-label-bold font-label-bold text-on-surface uppercase">Observações Adicionais</label>
            <textarea name="notes" class="w-full h-32 rounded-lg border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary bg-surface p-4 text-body-md" placeholder="Ex: Hóspede solicitou cobrança de item danificado em cartão separado..."></textarea>
          </div>
          
          <div class="flex flex-col gap-2">
            <label class="text-label-bold font-label-bold text-on-surface uppercase">Anexar Comprovação (Opcional)</label>
            <div class="border-2 border-dashed border-outline-variant rounded-lg h-32 flex flex-col items-center justify-center text-on-surface-variant hover:bg-surface-container transition-colors cursor-pointer" id="photo-upload-zone">
              <span class="material-symbols-outlined text-primary text-3xl mb-1">add_a_photo</span>
              <span class="text-label-bold font-label-bold">Tirar foto ou selecionar arquivo</span>
              <span class="text-[10px] opacity-60">PNG, JPG até 5MB</span>
            </div>
            <div class="hidden mt-2 flex gap-2 overflow-x-auto py-2" id="preview-container"></div>
          </div>
        </div>
      </div>

      <!-- Footer Action -->
      <div class="p-card-padding bg-surface-container-low border-t border-outline-variant flex flex-col md:flex-row justify-between items-center gap-4">
        <div class="flex items-center gap-2 text-on-surface-variant">
          <span class="material-symbols-outlined text-primary">info</span>
          <p class="text-body-md">Ao finalizar, o status do quarto mudará automaticamente para <span class="font-bold text-primary">Vistoria</span>.</p>
        </div>
        <button type="submit" class="w-full md:w-auto px-8 py-4 bg-primary text-white rounded-lg font-bold shadow-lg hover:bg-primary-container transition-all flex items-center justify-center gap-3 active:scale-95 cursor-pointer" id="finish-btn">
          Finalizar Check-out e Enviar para Limpeza
          <span class="material-symbols-outlined">send</span>
        </button>
      </div>
    </div>

    <!-- Warning for Missing items (Dynamic interaction) -->
    <div class="hidden mt-4 p-4 bg-error-container text-on-error-container rounded-lg border border-error flex items-start gap-3" id="warning-box">
      <span class="material-symbols-outlined text-error">warning</span>
      <div>
        <p class="font-bold">Atenção: Itens Pendentes</p>
        <p class="text-sm">Você marcou itens como 'Faltando' ou 'Danificado'. Certifique-se de que as cobranças foram lançadas no extrato do hóspede antes de liberar o check-out final.</p>
      </div>
    </div>
  <% end %>
</div>

<!-- Spacer for mobile footer visibility if needed -->
<div class="h-16 md:hidden"></div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Toggle warning box based on selection
    const radioButtons = document.querySelectorAll('input[type="radio"]');
    const warningBox = document.getElementById('warning-box');
    
    function checkIssues() {
      const hasIssues = Array.from(document.querySelectorAll('input[type="radio"]:checked'))
        .some(r => r.value === 'faltando' || r.value === 'danificado');
      
      if (hasIssues) {
        warningBox.classList.remove('hidden');
        warningBox.classList.add('flex');
      } else {
        warningBox.classList.add('hidden');
        warningBox.classList.remove('flex');
      }
    }

    radioButtons.forEach(radio => {
      radio.addEventListener('change', checkIssues);
    });

    // Simulating photo upload
    const uploadZone = document.getElementById('photo-upload-zone');
    const previewContainer = document.getElementById('preview-container');

    uploadZone.addEventListener('click', () => {
      previewContainer.classList.remove('hidden');
      const placeholderImg = document.createElement('div');
      placeholderImg.className = "w-16 h-16 rounded border border-outline-variant bg-center bg-cover flex-shrink-0 relative group bg-surface-container";
      
      const removeBtn = document.createElement('button');
      removeBtn.className = "absolute -top-1 -right-1 bg-red-600 text-white rounded-full w-4 h-4 flex items-center justify-center text-[10px]";
      removeBtn.innerHTML = "×";
      removeBtn.onclick = (e) => {
        e.stopPropagation();
        placeholderImg.remove();
        if (previewContainer.children.length === 0) previewContainer.classList.add('hidden');
      };
      
      // Simulated photo icon
      const photoIcon = document.createElement('span');
      photoIcon.className = "material-symbols-outlined absolute inset-0 m-auto text-outline-variant w-fit h-fit";
      photoIcon.innerHTML = "image";
      
      placeholderImg.appendChild(photoIcon);
      placeholderImg.appendChild(removeBtn);
      previewContainer.appendChild(placeholderImg);
    });
  });
</script>
